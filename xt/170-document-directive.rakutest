use v6.d;
use Test;
use RakuDoc::Render;

plan 11;

my $ast;
my $rv;
my RakuDoc::Processor $rdp .= new( :test );

# test rakudoc toc autogen
$ast = q:to/QAST/.AST;
    =begin rakudoc
    =head This is a header

    content
    =end rakudoc
    QAST
$rv = $rdp.render( $ast, :pre-finalised );
like $rv.rendered-toc, / 'This is a header' /, 'ToC is rendered';
$ast = q:to/QAST/.AST;
    =begin rakudoc
    =document :!auto-toc
    =head This is a header

    content
    =end rakudoc
    QAST

$rv = $rdp.render( $ast, :pre-finalised );
is $rv.rendered-toc, '', 'no ToC rendered';
$ast = q:to/QAST/.AST;
    =begin rakudoc
    =document :auto-toc<New Contents Table>
    =head This is a header

    content
    =end rakudoc
    QAST
$rv = $rdp.render( $ast, :pre-finalised );
like $rv.rendered-toc, /
    '<toc>' .+?
    'caption' .+? 'New Contents Table' .+?
    'This is a header'
/, 'Modified auto ToC is rendered';

$ast = q:to/QAST/.AST;
    =begin rakudoc
    =head This is a header

    content X<Some markup> stuff
    =end rakudoc
    QAST

$rv = $rdp.render( $ast, :pre-finalised );
like $rv.rendered-index, /
    '<index>' .+?
    'Some markup'
/, 'Index rendered';
$ast = q:to/QAST/.AST;
    =begin rakudoc
    =document :!auto-index
    =head This is a header

    content X<Some markup> stuff
    =end rakudoc
    QAST

$rv = $rdp.render( $ast, :pre-finalised );
is $rv.rendered-index, '', 'Index not rendered';
$ast = q:to/QAST/.AST;
    =begin rakudoc
    =document :auto-index<Glossary>
    =head This is a header

    content X<Some markup> stuff
    =end rakudoc
    QAST
$rv = $rdp.render( $ast, :pre-finalised );
like $rv.rendered-toc, /
'<index>' .+?
'caption' .+? 'Glossary' .+?
'This is a header'
/, 'Modified auto Index is rendered';

