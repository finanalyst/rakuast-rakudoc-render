#'caption' .+? 'Further reading' .+?
#'This is a header'
#/, 'Modified auto citations is rendered';

$ast = Q:to/QAST/.AST;
    =begin rakudoc
    Some thing G<to be said>inside letters.
    =end rakudoc
    QAST
$rv = $rdp.render( $ast, :pre-finalised );
like $rv.warnings[0], / '｢G｣' .+ 'is reserved for future' /, 'warning generated';
$ast = Q:to/QAST/.AST;
    =begin rakudoc
    =document :!error
    Some thing G<to be said>inside letters.
    =end rakudoc
    QAST
$rv = $rdp.render( $ast, :pre-finalised );
is $rv.warnings.elems, 0, 'warnings removed';

done-testing