#$n .= new: :init([4]);
	#is $n.numform( :form('%N:ord: %d:sc:pc'), :contents('warn about :sc and :pc') ),
#	@fnsh[++$xmp], "example $xmp";
#$n .= new: :init([5]);
	#is $n.numform( :form('%N:ord: %d:lc'),    :contents('no warning about :lc') ),
#	@fnsh[++$xmp], "example $xmp";
#$xmp++;
#is $n.numform( :form('%N(%a) %J.%R. %D'), :nums['',2,3,4], :contents('head1, not numhead1') ),
#	@fnsh[++$xmp], "example $xmp";
#is $n.numform( :form('%N(%a) %J.%R. %D'), :nums[1,'',3,4], :contents('head2, not numhead2') ),
#	@fnsh[++$xmp], "example $xmp";
#is $n.numform( :form('%N(%a) %J.%R. %D'), :nums[1,2,'',4], :contents('head3, not numhead3') ),
#	@fnsh[++$xmp], "example $xmp";
#is $n.numform( :form('%N(%a) %J.%R. %D'), :nums[1,2,3,''], :contents('head4, not numhead4') ),
#	@fnsh[++$xmp], "example $xmp";

done-testing;

