use v6.d;
use Test;
use RakuDoc::Numeration;

plan *;

my Numeration $n .= new;

is $n.Str, '1.', 'first level is 1';
is $n.inc(3).Str, '1.1.2.', 'incremented level 3 leaving others at 0';
is $n.inc(2).Str, '1.2.', ' incremented level2, which resets level 3';
is $n.reset.Str, '1.', 'resets to 1';
is $n.inc(1).Str, '2.', 'first level when incremented is 2';
is $n.inc(3).Str, '2.1.2.', 'incremented level 3 to stem = 2';
is $n.inc(2).Str, '2.2.', ' incremented level2, which resets level 3';
is $n.set(3,4).Str, '2.2.4.', 'set level3 to 4';
is $n.set(5,3).Str, '2.2.4.1.3.', 'set beyond last extent puts 1 in intermediate postion';

$n .= new: init => (1, 2, 7) ;
is $n.Str, '1.2.7.', 'create with initial sequence';

my $xmp = 0;
my @fnsh = $=finish.lines;
is $n.numform( :form('%%N%:        (%N of %n): %D:lc%:'),                :contents('The data') ),
	@fnsh[$xmp], "example $xmp";
is $n.numform( :form('%%N:ord%:    (%N:ord of %n:ord): %D%:'),           :contents('The data') ),
	@fnsh[++$xmp], "example $xmp";
is $n.numform( :form('%%N:ord:uc%: (%N:ord:uc of %N:ord:lc): %D:lc%:'),  :contents('The data') ),
	@fnsh[++$xmp], "example $xmp";
$xmp++;
is $n.numform( :form('%%R%:     (%R of %r): %D:lc%:'),          :contents('Example data') ),
	@fnsh[++$xmp], "example $xmp";
is $n.numform( :form('%%R:ord%: (%R:ord of %r:ord): %D:lc%:'),  :contents('Example data') ),
	@fnsh[++$xmp], "example $xmp";
$xmp++;
is $n.numform( :form('%%H%:     (%H of %h): %D:lc%:'),          :contents('Example data') ),
	@fnsh[++$xmp], "example $xmp";
is $n.numform( :form('%%ह%:     (%ह of %ह): %D:lc%:'),          :contents('Example data') ),
	@fnsh[++$xmp], "example $xmp";
is $n.numform( :form('%%H:ord%: (%H:ord of %h:ord): %D:lc%:'),  :contents('Example data') ),
	@fnsh[++$xmp], "example $xmp";
$xmp++;
is $n.numform( :form('%%B%:     (%B of %b): %D:lc%:'),          :contents('Example data') ),
	@fnsh[++$xmp], "example $xmp";
is $n.numform( :form('%%ব%:     (%ব of %ব): %D:lc%:'),          :contents('Example data') ),
	@fnsh[++$xmp], "example $xmp";
is $n.numform( :form('%%B:ord%: (%B:ord of %b:ord): %D:lc%:'),  :contents('Example data') ),
	@fnsh[++$xmp], "example $xmp";
$xmp++;
is $n.numform( :form('%%Z%:     (%Z of %z): %D:lc%:'),          :contents('Example data') ),
	@fnsh[++$xmp], "example $xmp";
is $n.numform( :form('%%大%:    (%大 of %小): %D:lc%:'),        :contents('Example data') ),
	@fnsh[++$xmp], "example $xmp";
is $n.numform( :form('%%Z:ord%: (%Z:ord of %z:ord): %D:lc%:'),  :contents('Example data') ),
	@fnsh[++$xmp], "example $xmp";
$xmp++;
is $n.numform( :form('%%J%:     (%J of %j): %D:lc%:'),          :contents('Example data') ),
	@fnsh[++$xmp], "example $xmp";
is $n.numform( :form('%%業%:    (%業 of %並): %D:lc%:'),        :contents('Example data') ),
	@fnsh[++$xmp], "example $xmp";
is $n.numform( :form('%%J:ord%: (%J:ord of %j:ord): %D:lc%:'),  :contents('Example data') ),
	@fnsh[++$xmp], "example $xmp";
$xmp++;
is $n.numform( :form('%T %R: %C'),            :caption('Mass-energy equivalence') :type<numformula> ),
        @fnsh[++$xmp], "example $xmp";
is $n.numform( :form('%N:ord %T:lc: %C:lc'),  :caption('Mass-energy equivalence') :type<numformula> ),
        @fnsh[++$xmp], "example $xmp";
$xmp++;
for 1...5, 17, 34 {
    $n .= new: :init( [$_] );
    is $n.numform( :form('%%N:ord:lang<cy>:lc%:  %N:ord:lang<cy>. %D'), :contents('Example data') ),
        @fnsh[++$xmp], "example $xmp"
}
$xmp++;
$n .= new: :init([1]);
	is $n.numform( :form('%A. %D'),         :contents('Design :form mechanism')  :type<numitem> ),
	@fnsh[++$xmp], "example $xmp";
$n .= new: :init([2]);
	is $n.numform( :form('%A. %d'),         :contents('Implement it (:lc)')            :type<numitem> ),
	@fnsh[++$xmp], "example $xmp";
$n .= new: :init([3]);
	is $n.numform( :form('%a. %D'),         :contents('???')                     :type<numitem> ),
	@fnsh[++$xmp], "example $xmp";
$n .= new: :init([4]);
	is $n.numform( :form('%A. %D:uc'),      :contents('Profit!!! (:uc)')               :type<numitem> ),
	@fnsh[++$xmp], "example $xmp";
$n .= new: :init([27]);
	is $n.numform( :form('%A. %D:tc'),     :contents('hUh? dOUblE ISO lEttErs? (:tc)')    :type<numitem> ),
	@fnsh[++$xmp], "example $xmp";
$n .= new: :init([731]);
	is $n.numform( :form('%A. %D:tclc'),  :contents('whAt??? trIplE the ISO lEttErs? (:tclc)') :type<numitem> ),
	@fnsh[++$xmp], "example $xmp";
$n .= new: :init([732]);
	is $n.numform( :form('%A. %D:sc'),    :contents('What else do i see, o, reader??? triple the ISO letters? (:sc)') :type<numitem> ),
	@fnsh[++$xmp], "example $xmp";
$n .= new: :init([732]);
	is $n.numform( :form('%A. %D:sc:lang<de>'),    :contents('What else do i see, o reader??? triple the ISO letters? (:sc:lang<de>)') :type<numitem> ),
	@fnsh[++$xmp], "example $xmp";
$n .= new: :init([732]);
	is $n.numform( :form('%A. %D:pc'),    :contents('whAt do i see now??? trIple the ISO lEttErs? (:pc)') :type<numitem> ),
	@fnsh[++$xmp], "example $xmp";
$xmp++;
#diag "Various warnings...";

#is $n.numform( :form('(%J:lc:uc:tclc of %並:pc:lang<fr>:ord): %Q %D:uc%:'), :nums[1,2,7], :contents('Example data') ),
