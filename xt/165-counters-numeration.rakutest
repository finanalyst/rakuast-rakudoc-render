    '<table>' .+?
    'caption:' .+? 'Caption for first table' .+?
    'numeration:' .+? '1.' .+?
    '</table>' .+?

    '<table>' .+?
    'caption:' .+? 'Caption for second table' .+?
    'numeration:' .+? '2.' .+?
    '</table>' .+?

    '<formula>' .+?
    'caption:' .+? 'Caption for first formula' .+?
    'numeration:' .+? '1.' .+?
    '</formula>'
    /, 'A2. Independent counters that reset';

