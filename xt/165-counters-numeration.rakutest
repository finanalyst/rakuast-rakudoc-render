$ast = Q:to/QAST/.AST;
    =begin rakudoc
    =config formula1  :counter< TableAndFormula >
    =config table1    :counter< TableAndFormula >
    =counter TableAndFormula :prefix<head1>

    =numhead1 Heading
    =numhead2 Subheading
    =numhead3 Subsubheading
        =for numtable1   :caption< Caption for first table >
        | one   | two  |
        =for numformula1 :caption< Caption for first formula >
        =for numtable1   :caption< Caption for second table >
        | one   | two  |
        =for numformula1 :caption< Caption for second formula >
    =numhead3 Subsubheading
    =begin section
        =config table1   :counter<SpecialTable>
        =counter SpecialTable :restart(1000)

        =for numtable1   :caption< Caption for first table >
        | one   | two  |
        =for numformula1 :caption< Caption for first formula >
        =for numtable1   :caption< Caption for second table >
        | one   | two  |
    =end section
    =numhead1 Second heading
        =for numtable1   :caption< Caption for next table >
        | one   | two  |
        =for numformula1 :caption< Caption for next formula >
    =end rakudoc
    QAST

