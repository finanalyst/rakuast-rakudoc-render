use v6.d;
use Test;
use RakuDoc::Render;
my $ast;
my $rv;
my RakuDoc::Processor $rdp .= new( :test );

plan 17;

$ast = Q:to/QAST/.AST;
    =begin rakudoc
    =numhead1 Heading
    =numhead2 Subheading
    =numhead3 Subsubheading
        =for numtable1   :caption< Caption for first table >
        | one   | two  |
        =for numformula1 :caption< Caption for first formula >
        =for numtable1   :caption< Caption for second table >
        | one   | two  |
        =for numformula1 :caption< Caption for second formula >
    =numhead3 Subsubheading
        =for numtable1   :caption< Caption for first table >
        | one   | two  |
        =for numtable1   :caption< Caption for second table >
        | one   | two  |
        =for numformula1 :caption< Caption for first formula >
    =end rakudoc
    QAST

$rv = $rdp.render( $ast, :pre-finalised );
like $rv.body.Str, /
    '<head>' .+?
    'contents:' .+? 'Heading' .+?
    'numeration:' .+ '1.' .+?
    '</head>' .+?

    '<head>' .+?
    'contents:' .+? 'Subheading' .+?
    'numeration:' .+ '1.1.' .+?
    '</head>' .+?

    '<head>' .+?
    'contents:' .+? 'Subsubheading' .+?
    'numeration:' .+ '1.1.1.' .+?
    '</head>' .+?

    '<table>' .+?
    'caption:' .+? 'Caption for first table' .+?
    '</table>' .+?

    '<formula>' .+?
    'caption:' .+? 'Caption for first formula' .+?
    'numeration:' .+? '1.' .+?
    '</formula>' .+?

    '<table>' .+?
    'caption:' .+? 'Caption for second table' .+?
    'numeration:' .+? '2.' .+?
    '</table>' .+?

    '<formula>' .+?
    'caption:' .+? 'Caption for second formula' .+?
    'numeration:' .+? '2.' .+?
    '</formula>' .+?

    '<head>' .+?
    'contents:' .+? 'Subsubheading' .+?
    'numeration:' .+ '1.1.2.' .+?
    '</head>' .+?

    '<table>' .+?
    'caption:' .+? 'Caption for first table' .+?
    'numeration:' .+? '3.' .+?
    '</table>' .+?

    '<table>' .+?
    'caption:' .+? 'Caption for second table' .+?
    'numeration:' .+? '4.' .+?
    '</table>' .+?

    '<formula>' .+?
    'caption:' .+? 'Caption for first formula' .+?
    'numeration:' .+? '3.' .+?
    '</formula>'
    /, 'A1. Independent counters that don’t reset';

$ast = Q:to/QAST/.AST;
    =begin rakudoc
    =numhead1 Heading
    =numhead2 Subheading
    =numhead3 Subsubheading
        =for numtable1   :caption< Caption for first table >
        | one   | two  |
        =for numformula1 :caption< Caption for first formula >
        =for numtable1   :caption< Caption for second table >
        | one   | two  |
        =for numformula1 :caption< Caption for second formula >
    =numhead3 Subsubheading
    =counter table1 :restart
        =for numtable1   :caption< Caption for first table >    :!continued
        | one   | two  |
        =for numtable1   :caption< Caption for second table >
        | one   | two  |
    =counter formula1 :restart
        =for numformula1 :caption< Caption for first formula >  :!continued
    =end rakudoc
    QAST

$rv = $rdp.render( $ast, :pre-finalised );
like $rv.body.Str, /
